# Copy to .env and fill in values before `docker compose up`.
# docker compose auto-loads .env from the same directory as the compose file.

# Required. Every /api/* request must send this as X-API-Key.
# Generate one with: openssl rand -hex 32
API_SHARED_KEY=change-me-to-a-long-random-string

# Host port nginx will listen on (left side of "8080:80" in compose).
# Change to 80 for production, or any other free port on dev machines.
WEB_PORT=8080

# CORS — with the default nginx front, everything is same-origin so this
# only matters if you also call the API from another origin (e.g. a mobile app).
# Comma-separated list, or "*" for any origin.
ALLOWED_ORIGINS=http://localhost:8080

# Per-upload cap on the API side. Must be <= nginx's client_max_body_size
# (set to 100m in deploy/nginx.conf). If you bump this above 100, also edit
# deploy/nginx.conf.
MAX_UPLOAD_MB=100
