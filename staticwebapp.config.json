{
  "routes": [
    { "route": "/login", "redirect": "/.auth/login/aad" },
    { "route": "/logout", "redirect": "/.auth/logout" },
    { "route": "/tailwinds.css", "allowedRoles": ["anonymous", "authenticated"] },
    { "route": "/private.html", "allowedRoles": [ "admin", "authenticated"] }
  ],
  "responseOverrides": {
    "401": { "statusCode": 302, "redirect": "/.auth/login/aad" },
    "403": { "rewrite": "/forbidden.html" }
  }
}
